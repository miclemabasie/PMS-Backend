    {
      "name": "3️⃣ Receipts",
      "item": [
        {
          "name": "Get Receipt by Payment ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlordToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/receipts/{{paymentId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "receipts", "{{paymentId}}"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Receipt data structure is valid', function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.be.an('object');",
                  "    pm.expect(data).to.have.property('payment');",
                  "    pm.expect(data).to.have.property('tenant');",
                  "    pm.expect(data).to.have.property('property');",
                  "    pm.expect(data).to.have.property('unit');",
                  "    pm.expect(data).to.have.property('landlord');",
                  "    pm.expect(data).to.have.property('template');",
                  "});",
                  "pm.test('Payment fields exist', function () {",
                  "    const data = pm.response.json();",
                  "    const payment = data.payment;",
                  "    pm.expect(payment).to.have.property('amount');",
                  "    pm.expect(payment).to.have.property('payment_date');",
                  "    pm.expect(payment).to.have.property('payment_method');",
                  "    pm.expect(payment).to.have.property('status');",
                  "    pm.expect(payment).to.have.property('fee_breakdown');",
                  "});",
                  "pm.test('Tenant fields exist', function () {",
                  "    const data = pm.response.json();",
                  "    const tenant = data.tenant;",
                  "    pm.expect(tenant).to.have.property('name');",
                  "    pm.expect(tenant).to.have.property('email');",
                  "});",
                  "pm.test('Property fields exist', function () {",
                  "    const data = pm.response.json();",
                  "    const property = data.property;",
                  "    pm.expect(property).to.have.property('name');",
                  "    pm.expect(property).to.have.property('address');",
                  "});",
                  "pm.test('Template fields exist', function () {",
                  "    const data = pm.response.json();",
                  "    const template = data.template;",
                  "    pm.expect(template).to.have.property('layout');",
                  "    pm.expect(template).to.have.property('primary_color');",
                  "    pm.expect(template).to.have.property('agency_name');",
                  "});"
                ]
              }
            }
          ]
        },

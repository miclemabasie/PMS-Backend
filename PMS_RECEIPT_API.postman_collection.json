    {
      "name": "2️⃣ Payments",
      "item": [
        {
          "name": "Record Manual Payment (Cash) - triggers receipt generation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlordToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150000,\n  \"payment_method\": \"cash\",\n  \"payment_date\": \"2026-07-01\",\n  \"notes\": \"Test manual payment for receipt\",\n  \"pin\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/agreements/{{agreementId}}/manual-payment/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "agreements", "{{agreementId}}", "manual-payment"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Payment recorded', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.status).to.equal('completed');",
                  "    pm.environment.set('paymentId', jsonData.id);",
                  "});"
                ]
              }
            }
          ]
        },

{
    "info": {
        "name": "Blizton Rental Payments API",
        "description": "Tests for payment plans, rental agreements, and flexible payments (monthly/yearly, installments, custom amounts).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost/api/v1/payments"
        },
        {
            "key": "tenant_id",
            "value": "replace-with-real-tenant-uuid"
        },
        {
            "key": "unit_id",
            "value": "replace-with-real-unit-uuid"
        },
        {
            "key": "payment_plan_id",
            "value": ""
        },
        {
            "key": "agreement_id",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "1. Payment Plans",
            "item": [
                {
                    "name": "1.1 Create Monthly Plan (any months up to 12, custom amounts allowed)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/payment-plans/",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Monthly Flexible\",\n  \"mode\": \"monthly\",\n  \"allowed_monthly_terms\": [],\n  \"max_months\": 12,\n  \"allow_custom_amount\": true,\n  \"amount_step\": 10,\n  \"is_active\": true\n}"
                        }
                    },
                    "response": []
                },
                {
                    "name": "1.2 Create Monthly Plan (only 1,3,6 months, no custom)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/payment-plans/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Monthly Fixed Terms\",\n  \"mode\": \"monthly\",\n  \"allowed_monthly_terms\": [1,3,6],\n  \"max_months\": 6,\n  \"allow_custom_amount\": false,\n  \"amount_step\": 10,\n  \"is_active\": true\n}"
                        }
                    }
                },
                {
                    "name": "1.3 Create Yearly Plan with 60/40 installments",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/payment-plans/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Yearly 60/40 with due dates\",\n  \"mode\": \"yearly\",\n  \"show_full_payment_option\": true,\n  \"enforce_installment_order\": true,\n  \"allow_custom_amount\": false,\n  \"amount_step\": 10,\n  \"is_active\": true\n}"
                        }
                    },
                    "postresponse": [
                        {
                            "assign": {
                                "key": "payment_plan_id",
                                "value": "{{response.json().id}}"
                            }
                        }
                    ]
                },
                {
                    "name": "1.4 Add Installments to Yearly Plan",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/payment-plans/{{payment_plan_id}}/installments/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"percent\": 60,\n  \"due_date\": \"2026-03-01\",\n  \"order_index\": 0\n}"
                        }
                    }
                },
                {
                    "name": "1.5 Add Second Installment",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/payment-plans/{{payment_plan_id}}/installments/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"percent\": 40,\n  \"due_date\": \"2026-09-01\",\n  \"order_index\": 1\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Rental Agreements",
            "item": [
                {
                    "name": "2.1 Create Agreement (monthly plan)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"unit_id\": \"{{unit_id}}\",\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"payment_plan_id\": \"{{monthly_plan_id}}\"\n}"
                        }
                    },
                    "postresponse": [
                        {
                            "assign": {
                                "key": "agreement_id",
                                "value": "{{response.json().id}}"
                            }
                        }
                    ]
                },
                {
                    "name": "2.2 Create Agreement (yearly plan with installments)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"unit_id\": \"{{unit_id}}\",\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"payment_plan_id\": \"{{yearly_plan_id}}\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Get Available Payment Options",
            "item": [
                {
                    "name": "3.1 Options for Monthly Agreement",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/agreements/{{agreement_id}}/options/"
                    },
                    "tests": {
                        "Status 200": "pm.response.to.have.status(200);",
                        "Contains monthly options": "pm.expect(pm.response.json()).to.be.an('array');"
                    }
                },
                {
                    "name": "3.2 Options for Yearly Agreement",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/agreements/{{yearly_agreement_id}}/options/"
                    }
                }
            ]
        },
        {
            "name": "4. Make Payments (Monthly Mode)",
            "item": [
                {
                    "name": "4.1 Pay 1 month (exact)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 150000,\n  \"payment_method\": \"mtn_momo\",\n  \"phone_number\": \"677123456\",\n  \"provider\": \"MTN\"\n}"
                        }
                    },
                    "tests": {
                        "Payment completed": "pm.response.to.have.status(201);",
                        "Status = completed": "pm.expect(pm.response.json().status).to.eql('completed');"
                    }
                },
                {
                    "name": "4.2 Pay 3 months (if allowed)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 450000,\n  \"payment_method\": \"orange_money\",\n  \"phone_number\": \"699123456\",\n  \"provider\": \"ORANGE\"\n}"
                        }
                    }
                },
                {
                    "name": "4.3 Pay custom amount (monthly with custom allowed)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 75000,\n  \"payment_method\": \"cash\"\n}"
                        }
                    }
                },
                {
                    "name": "4.4 Invalid amount (not multiple of step) – should fail",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 77777,\n  \"payment_method\": \"bank_transfer\"\n}"
                        }
                    },
                    "tests": {
                        "Error 400": "pm.response.to.have.status(400);",
                        "Error message contains step": "pm.expect(pm.response.json().error).to.include('multiple');"
                    }
                }
            ]
        },
        {
            "name": "5. Make Payments (Yearly Installment Mode)",
            "item": [
                {
                    "name": "5.1 Pay first installment (60%)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{yearly_agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 180000,\n  \"payment_method\": \"mtn_momo\",\n  \"phone_number\": \"677123456\",\n  \"provider\": \"MTN\"\n}"
                        }
                    }
                },
                {
                    "name": "5.2 Pay second installment (40%) after first is paid",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{yearly_agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 120000,\n  \"payment_method\": \"orange_money\"\n}"
                        }
                    }
                },
                {
                    "name": "5.3 Pay full year upfront",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{yearly_agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 300000,\n  \"payment_method\": \"bank_transfer\"\n}"
                        }
                    }
                },
                {
                    "name": "5.4 Pay custom amount (if custom allowed) – partial first installment",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{yearly_agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 50000,\n  \"payment_method\": \"cash\"\n}"
                        }
                    }
                },
                {
                    "name": "5.5 Try to pay second installment before first – should fail if enforce_order=true",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/agreements/{{yearly_agreement_id}}/pay/",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 120000,\n  \"payment_method\": \"mtn_momo\"\n}"
                        }
                    },
                    "tests": {
                        "Error 400": "pm.response.to.have.status(400);"
                    }
                }
            ]
        },
        {
            "name": "6. Edge Cases & Verification",
            "item": [
                {
                    "name": "6.1 Check agreement status after payments",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/agreements/{{agreement_id}}/"
                    },
                    "tests": {
                        "Coverage end date updated": "pm.expect(pm.response.json().coverage_end_date).to.not.be.null;"
                    }
                },
                {
                    "name": "6.2 List all payments for an agreement",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/payments/?agreement={{agreement_id}}"
                    }
                }
            ]
        }
    ]
}
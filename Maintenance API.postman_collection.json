            "url": {
              "raw": "{{baseUrl}}/reports/maintenance/analytics/{{propertyId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "maintenance", "analytics", "{{propertyId}}", ""]
            },
            "description": "Get detailed maintenance analytics (costs by vendor, monthly trends, priority breakdown)."
          }
        }
      ]
    },
    {
      "name": "🔄 Complete Workflow (Full Test)",
      "item": [
        {
          "name": "▶️ Full Maintenance Workflow",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Run this workflow manually by executing requests in order: 1→2→3→4→5→6"
          }
        },
        {
          "name": "Step 1: Tenant Creates Request (Set maintenanceRequestId)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"unit_id\": \"{{unitId}}\",\n    \"title\": \"Complete Bathroom Renovation Required\",\n    \"description\": \"The bathroom tiles are broken, shower head is rusted, and the sink is cracked. This requires complete renovation.\",\n    \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", ""]
            }
          }
        },
        {
          "name": "Step 2: Landlord Views All Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", ""]
            }
          }
        },
        {
          "name": "Step 3: Landlord Marks In Progress",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/status/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", "status", ""]
            }
          }
        },
        {
          "name": "Step 4: Landlord Marks Complete (Creates Expense)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"actual_cost\": 150000,\n    \"notes\": \"Complete bathroom renovation done. New tiles, shower, sink, and plumbing installed.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/complete/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", "complete", ""]
            }
          }
        },
        {
          "name": "Step 5: Verify Expense Created",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/expenses/?maintenance_request_id={{maintenanceRequestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", ""],
              "query": [
                {
                  "key": "maintenance_request_id",
                  "value": "{{maintenanceRequestId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Step 6: Tenant Views Completed Request",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", ""]
            }
          }
        }
      ]
    }
  ]

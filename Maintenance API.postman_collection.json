            "url": {
              "raw": "{{baseUrl}}/reports/expenses/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", ""]
            },
            "description": "List all expenses for properties owned/managed by the landlord."
          }
        },
        {
          "name": "4. List Expenses with Filters",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/expenses/?property={{propertyId}}&category=maintenance",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", ""],
              "query": [
                {
                  "key": "property",
                  "value": "{{propertyId}}"
                },
                {
                  "key": "category",
                  "value": "maintenance"
                }
              ]
            },
            "description": "List expenses filtered by property and category."
          }
        },
        {
          "name": "5. Get Expense Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/expenses/{{expenseId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", "{{expenseId}}", ""]
            },
            "description": "Get detailed information about a specific expense."
          }
        },
        {
          "name": "6. Update Expense (Landlord)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"description\": \"Updated: Replaced faucet and pipes - additional labor cost\",\n    \"amount\": 27000\n}"

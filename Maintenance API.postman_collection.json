  "item": [
    {
      "name": "🔥 Maintenance Requests",
      "item": [
        {
          "name": "1. Create Maintenance Request (Tenant)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "multipart/form-data",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "unit_id",
                  "value": "{{unitId}}",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "Leaking Faucet in Kitchen",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "The kitchen sink faucet is constantly dripping water. It has been leaking for 2 days and is wasting water. Please fix as soon as possible.",
                  "type": "text"
                },
                {
                  "key": "priority",
                  "value": "medium",
                  "type": "text"
                },
                {
                  "key": "notes",
                  "value": "I've placed a bucket underneath to catch the water.",
                  "type": "text"
                },
                {
                  "key": "images",
                  "value": "",
                  "type": "file"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", ""]
            },
            "description": "Create a new maintenance request as a tenant. Images are optional (max 5)."
          }
        },
        {
          "name": "2. List Maintenance Requests (Landlord)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", ""]
            },
            "description": "List all maintenance requests for properties owned/managed by the landlord."
          }
        },
        {
          "name": "3. List Maintenance Requests (Tenant)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", ""]
            },
            "description": "List all maintenance requests submitted by the tenant (only their own)."
          }
        },
        {
          "name": "4. List with Filters (Landlord)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/?status=submitted&priority=high",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", ""],
              "query": [
                {
                  "key": "status",
                  "value": "submitted"
                },
                {
                  "key": "priority",
                  "value": "high"
                }
              ]
            },
            "description": "List maintenance requests with filters (status, priority, property)."
          }
        },
        {
          "name": "5. Get Maintenance Request Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", ""]
            },
            "description": "Get detailed information about a specific maintenance request."
          }
        },
        {
          "name": "6. Update Status to In Progress (Landlord)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/status/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", "status", ""]
            },
            "description": "Update the status to 'in_progress'. This will notify the tenant via email."
          }
        },
        {
          "name": "7. Update Status to Cancelled (Landlord)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"cancelled\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/status/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", "status", ""]
            },
            "description": "Cancel a maintenance request. This will notify the tenant via email."
          }
        },
        {
          "name": "8. Complete Request with Cost (Landlord)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"actual_cost\": 25000,\n    \"notes\": \"Fixed by professional plumber. Replaced the entire faucet system. New pipes installed.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/complete/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", "complete", ""]
            },
            "description": "Complete a maintenance request. This automatically creates an expense record and notifies the tenant via email."
          }
        },
        {
          "name": "9. Update Request (Add More Images)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "multipart/form-data",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "notes",
                  "value": "Update: The leak has gotten worse. Please prioritize this.",
                  "type": "text"
                },
                {
                  "key": "images",
                  "value": "",
                  "type": "file"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", ""]
            },
            "description": "Update a maintenance request (add notes, add more images). Only available if status is 'submitted'."
          }
        },
        {
          "name": "10. Attempt Delete (Should Fail)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maintenance/requests/{{maintenanceRequestId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["maintenance", "requests", "{{maintenanceRequestId}}", ""]
            },
            "description": "⚠️ This endpoint should return a 405 or 403. Deletion is NOT allowed by design."
          }
        }
      ]
    },
    {
      "name": "💰 Expenses",
      "item": [
        {
          "name": "1. Create Expense (Landlord)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"

            "body": {
              "mode": "raw",
              "raw": "{\n    \"property_id\": \"{{propertyId}}\",\n    \"category\": \"utility\",\n    \"amount\": 45000,\n    \"expense_date\": \"2026-07-01\",\n    \"description\": \"Monthly water bill for entire building\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reports/expenses/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", ""]
            },
            "description": "Create an expense without linking to a maintenance request."

            "url": {
              "raw": "{{baseUrl}}/reports/expenses/{{expenseId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", "{{expenseId}}", ""]
            },
            "description": "Update an existing expense (partial update)."
          }
        },
        {
          "name": "7. Delete Expense (Landlord)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/expenses/{{expenseId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", "{{expenseId}}", ""]
            },
            "description": "Delete an expense. Use with caution."
          }
        }
      ]
    },
    {
      "name": "📊 Maintenance Reports",
      "item": [
        {
          "name": "1. Maintenance Summary (Landlord)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/maintenance/property/{{propertyId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "maintenance", "property", "{{propertyId}}", ""]
            },
            "description": "Get maintenance summary for a property (total requests, costs by status/priority)."
          }
        },
        {
          "name": "2. Maintenance Summary with Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{landlord_access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/maintenance/property/{{propertyId}}/?start=2026-06-01&end=2026-07-02",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "maintenance", "property", "{{propertyId}}", ""],
              "query": [
                {
                  "key": "start",
                  "value": "2026-06-01"
                },
                {
                  "key": "end",
                  "value": "2026-07-02"
                }
              ]
            },
            "description": "Get maintenance summary for a date range."
          }
        },
        {
          "name": "3. Maintenance Analytics (Advanced)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",

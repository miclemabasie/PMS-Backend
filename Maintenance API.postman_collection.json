            "body": {
              "mode": "raw",
              "raw": "{\n    \"property_id\": \"{{propertyId}}\",\n    \"category\": \"maintenance\",\n    \"amount\": 25000,\n    \"expense_date\": \"2026-07-02\",\n    \"description\": \"Replacement of kitchen faucet and pipes\",\n    \"maintenance_request_id\": \"{{maintenanceRequestId}}\",\n    \"is_reimbursable\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reports/expenses/",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "expenses", ""]
